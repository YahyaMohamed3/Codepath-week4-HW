# Copy this file to .env and fill in your real key.
# Never commit your real .env file.

# Groq API key used by the semantic detection signal.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_key_here

# Optional: override the Groq model (defaults to llama-3.3-70b-versatile).
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: path to the SQLite database file (defaults to provenance_guard.db).
# PROVENANCE_DB_PATH=provenance_guard.db

# Optional: Flask secret key for session/security features.
# SECRET_KEY=change-me-in-production
